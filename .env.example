# =============================================================================
# .env.example — Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# =============================================================================

# ── MySQL Source ──────────────────────────────────────────────────────────────
MYSQL_SOURCE_HOST=localhost
MYSQL_SOURCE_PORT=3306
MYSQL_SOURCE_USER=root
MYSQL_SOURCE_PASSWORD=your_mysql_password
MYSQL_SOURCE_DB=source_db

# ── SQL Server Source ─────────────────────────────────────────────────────────
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=your_sqlserver_password
SQLSERVER_DB=source_db
# SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server   # Uncomment and adjust if needed

# ── MySQL Target ──────────────────────────────────────────────────────────────
MYSQL_TARGET_HOST=localhost
MYSQL_TARGET_PORT=3306
MYSQL_TARGET_USER=root
MYSQL_TARGET_PASSWORD=your_mysql_password
MYSQL_TARGET_DB=etl_output
